--- a/modules/misc/webservices/musicbrainz.c
+++ b/modules/misc/webservices/musicbrainz.c
@@ -61,10 +61,15 @@ static musicbrainz_lookup_t * musicbrainz_lookup(vlc_object_t *p_obj, const char
         return NULL;
     }
 
